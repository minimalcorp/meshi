{
  "name": "meshi-docs",
  "version": "0.0.0",
  "private": true,
  "description": "meshi documentation site (Nextra).",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 --port 6260",
    "build": "next build",
    "postbuild": "pagefind --site out --output-subdir _pagefind",
    "start": "next start --port 6260",
    "lint": "eslint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^16.0.0",
    "nextra": "^4.6.0",
    "nextra-theme-docs": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "pagefind": "^1.5.2",
    "typescript": "5.9.3"
  }
}
